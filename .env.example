# Find Your Floor, site-assistant build env (TEMPLATE)
# Copy to .env (gitignored) and fill. Never commit the real .env.

# --- Anthropic (the brain) ---
# Ilya's own metered API key. Sonnet 4.6 default per the build plan.
ANTHROPIC_API_KEY=
ASSISTANT_MODEL=claude-sonnet-4-6
# Cost guards (Phase 0 ceilings)
MAX_TOKENS_PER_SESSION=
DAILY_SPEND_CEILING_EUR=

# --- WooCommerce (live product pull, READ scope) ---
WOO_BASE_URL=https://lux-floor.de
WOO_CONSUMER_KEY=
WOO_CONSUMER_SECRET=

# --- Bitrix24 (lead capture), PHASE 2, fill when Aleksey delivers the webhook ---
# Inbound webhook URL with crm scope (this is Bitrix's "API key")
BITRIX_WEBHOOK_URL=

# --- Twenty CRM (lead capture), replaces Bitrix, migration in progress ---
# API base (cloud: https://api.twenty.com, self-hosted: https://your-domain/rest)
TWENTY_API_URL=https://api.twenty.com
# Long-lived API token from Settings, API and Webhooks (Bearer token)
TWENTY_API_KEY=
# Workspace member id of the lead owner (Alisa). Leads get assigned to her.
# Leave empty until Alisa is invited to the Twenty workspace, then fill.
TWENTY_OWNER_ID=

# --- Telegram Smart Buzz (hot-lead alert), PHASE 2, reuse CommandOS bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_HOT_THREAD_ID=

# --- Observability ---
# Render API key (operator pastes it). Lets Claude set env vars and trigger
# deploys via the API, so no manual dashboard steps are needed.
RENDER_API_KEY=
# Token gating GET /admin/conversations (long random string). Also set in Render.
ADMIN_TOKEN=
# Conversation log path (default: conversations.jsonl next to the app, ephemeral).
LOG_PATH=
# Render Deploy Hook URL (operator-only, used locally to trigger a deploy).
RENDER_DEPLOY_HOOK=
